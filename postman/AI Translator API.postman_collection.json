        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"Artificial intelligence is transforming the world\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/analyze",
          "host": ["{{base_url}}"],
          "path": ["analyze"]
        }
      }
    },
    {
